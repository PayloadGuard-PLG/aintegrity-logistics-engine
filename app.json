{
  "expo": {
    "name": "AIntegrity Logistics Engine",
    "slug": "logistics-engine",
    "scheme": "logisticsengine",
    "version": "1.0.0",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0c"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "android": {
      "package": "com.payloadguard.logisticsengine",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a0c"
      }
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Logistics Engine to select screenshots from your photo library."
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/d61de2f2-abc7-495e-a89a-03ee878db83b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d61de2f2-abc7-495e-a89a-03ee878db83b"
      }
    },
    "owner": "sdarkvader"
  }
}
